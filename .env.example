# =========================
# Flask / App
# =========================
APP_ENV=dev
FLASK_DEBUG=1
PORT=5000
SECRET_KEY=change-me-in-production
SECRET_KEY=key-to-change-in-production

# =========================
# Database
# ========================= 
# SQLite local (padrão)
DATABASE_URL=sqlite:///prontuario.db
# Exemplo PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/prontuario

# =========================
# Paginação
# =========================
PACIENTES_PER_PAGE=20

# =========================
# Feature Flags
# =========================
FEATURE_DEV_MODE=1
FEATURE_RBAC_STRICT=1
FEATURE_ALLOW_CREATE_WITHOUT_UNIT=0
FEATURE_BYPASS_PACIENTE_SCOPE=0